{
  "compilerOptions": {
    "outDir": "dist",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": ["ESNext", "DOM"],
    "allowJs": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"],
      "@images/*": ["images/*"],
      "@api/*": ["api/*"],
      "@api": ["api"],
      "@layouts/*": ["views/layouts/*"],
      "@layouts": ["views/layouts"],
      "@modules/*": ["views/modules/*"],
      "@modules": ["views/modules"],
      "@styles/*": ["styles/*"],
      "@styles": ["styles"],
      "@lib/*": ["lib/*"],
      "@lib": ["lib"],
      "@entities/*": ["entities/*"],
      "@entities": ["entities"],
      "@adapters/*": ["adapters/*"],
      "@adapters": ["adapters"],
      "@views/*": ["views/*"],
      "@views": ["views"]
    },
    "jsx": "react-jsx"
  },
  "include": ["src", "modules.d.ts"]
}
